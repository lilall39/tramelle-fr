NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
# URL canonique du site (partage, liens absolus). Ex. https://www.votredomaine.fr — optionnel en dev si vous testez dans le navigateur.
NEXT_PUBLIC_BASE_URL=

# Envoi e-mail serveur (Resend : https://resend.com — distinct de Firebase). Copier aussi sur Vercel.
RESEND_API_KEY=
# Ex. test : Tramelle <onboarding@resend.dev> — prod : adresse @domaine vérifié chez Resend
EMAIL_FROM=
# Compte de service Firebase (API serveur) — préférer BASE64 (évite les soucis de guillemets sur une longue ligne)
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
# Alternative : JSON sur une ligne (sans variable BASE64)
FIREBASE_SERVICE_ACCOUNT_JSON=
